{
  "name": "@theyahia/salutespeech-mcp",
  "version": "1.1.0",
  "description": "MCP server for SaluteSpeech — speech recognition and synthesis (Russia)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "salutespeech-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "smithery.yaml"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/salutespeech-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "russian-api",
    "salutespeech",
    "sber",
    "speech",
    "tts",
    "stt",
    "speech-recognition",
    "text-to-speech",
    "api",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/salutespeech-mcp.git"
  },
  "homepage": "https://github.com/theYahia/salutespeech-mcp#readme",
  "author": "Yahia"
}
